{
  "graph": {
    "tenantId": "00000000-0000-0000-0000-000000000000",
    "clientId": "00000000-0000-0000-0000-000000000000",
    "authMode": "Interactive"
  },
  "exchangeOnline": {
    "enabled": true,
    "authMode": "Interactive",
    "includeInboxRules": false,
    "includeMailboxStatistics": false,
    "inboxRuleMailboxLimit": 200
  },
  "licensePricing": {
    "enabled": true,
    "priceMapPath": "config/license-prices.sample.json",
    "defaultCurrency": "CAD"
  },
  "users": {
    "includeSignInActivity": true
  },
  "sharePoint": {
    "adminUrl": "https://contoso-admin.sharepoint.com",
    "enabled": true,
    "includeOneDrive": true,
    "reportPeriodDays": 90,
    "siteSource": "Auto"
  },
  "teams": {
    "reportPeriodDays": 90,
    "includeOwnersAndMembers": false
  },
  "devices": {
    "staleAfterDays": 90,
    "includeIntune": true
  },
  "copilot": {
    "includeUsageReport": true
  },
  "ai": {
    "enabled": false,
    "endpoint": "https://example.openai.azure.com/openai/deployments/YOUR_DEPLOYMENT/chat/completions?api-version=2025-01-01-preview",
    "apiKeyEnvironmentVariable": "TENANT_REVIEW_AI_API_KEY",
    "model": "configured-by-endpoint"
  },
  "rendering": {
    "reportTemplate": "templates/report-template.docx",
    "deckTemplate": "templates/deck-template.pptx"
  }
}
